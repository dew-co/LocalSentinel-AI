{
  "name": "localsentinel-ai-vscode",
  "displayName": "LocalSentinel AI",
  "description": "Placeholder VS Code extension structure for future LocalSentinel AI integration.",
  "version": "0.1.0",
  "publisher": "localsentinel",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "localsentinel.openAssistant", "title": "LocalSentinel: Open Assistant" },
